{
  "run_id": "example-feedback",
  "provider": "default",
  "collector_version": "0.1.0",
  "output_dir": "runs",
  "targets": [
    {"context": "cluster-alpha", "label": "cluster-alpha"},
    {"context": "cluster-beta", "label": "cluster-beta"},
    {"context": "cluster-gamma", "label": "cluster-gamma"}
  ],
  "pairs": [
    {
      "primary": "cluster-alpha",
      "secondary": "cluster-beta",
      "label": "alpha-vs-beta",
      "assess": true,
      "intent": "suspicious-drift",
      "expected_drift_categories": ["helm_releases"],
      "unexpected_drift_categories": ["metadata"],
      "notes": "Production primaries should stay in sync so deviations are suspicious."
    },
    {
      "primary": "cluster-alpha",
      "secondary": "cluster-gamma",
      "label": "alpha-vs-gamma",
      "assess": true,
      "intent": "expected-drift",
      "expected_drift_categories": ["region", "node_count"],
      "unexpected_drift_categories": ["helm_releases"],
      "notes": "Gamma hosts the DR inventory so Helm releases may drift intentionally."
    }
  ]
}

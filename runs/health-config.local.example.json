{
  "run_label": "fleet-health",
  "collector_version": "0.1.0",
  "output_dir": "runs",
  "targets": [
    {
      "context": "cluster-alpha",
      "label": "cluster-alpha",
      "monitor_health": true,
      "watched_helm_releases": ["kube-system/observability"],
      "watched_crd_families": ["monitoring.example.com"],
      "cluster_class": "production",
      "cluster_role": "primary",
      "baseline_cohort": "fleet-production"
    },
    {
      "context": "cluster-beta",
      "label": "cluster-beta",
      "monitor_health": true,
      "watched_helm_releases": ["kube-system/observability", "platform/cluster-ops"],
      "watched_crd_families": ["database.example.com"],
      "cluster_class": "production",
      "cluster_role": "primary",
      "baseline_cohort": "fleet-production"
    },
    {
      "context": "cluster-gamma",
      "label": "cluster-gamma",
      "monitor_health": false,
      "watched_helm_releases": ["platform/cluster-ops"],
      "watched_crd_families": [],
      "cluster_class": "dr",
      "cluster_role": "secondary",
      "baseline_cohort": "fleet-dr"
    }
  ],
  "peer_mappings": [
    {
      "primary": "cluster-alpha",
      "secondary": "cluster-beta",
      "intent": "suspicious-drift",
      "expected_drift_categories": ["watched_helm_release"],
      "notes": "Same-role parity comparison for production primaries."
    }
  ],
  "comparison_triggers": {
    "control_plane_version": true,
    "watched_helm_release": true,
    "watched_crd": true,
    "health_regression": true,
    "missing_evidence": true,
    "manual": true,
    "warning_event_threshold": 5
  },
  "manual_pairs": [],
  "external_analysis": {
    "policy": {
      "manual": true,
      "degraded_health": false,
      "suspicious_comparison": false
    },
    "adapters": [
      { "name": "k8sgpt", "enabled": true, "command": ["k8sgpt", "analysis"] }
    ]
  },
  "baseline_policy_path": "health-baseline.example.json"
}
